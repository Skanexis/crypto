NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
DATABASE_PATH=./data/crypto_invoices.db

# Admin
ADMIN_API_KEY=change-me-now
ADMIN_TELEGRAM_IDS=123456789

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=super-secret-path

# Webhook security
PAYMENT_WEBHOOK_HMAC_SECRET=webhook-shared-secret

# Invoice
INVOICE_TTL_MINUTES=30
PAYMENT_AMOUNT_TOLERANCE_PCT=1
PAYMENT_AMOUNT_MAX_OVER_PCT=3
STRICT_AMOUNT_MATCH=true
PAYMENT_LATE_GRACE_MINUTES=15
PAYMENT_EARLY_MATCH_GRACE_SECONDS=0
UNIQUE_AMOUNT_MAX_BUMPS=2000

# Auto verify on-chain
AUTO_VERIFY_PAYMENTS=true
VERIFY_INTERVAL_SECONDS=45
PROVIDER_REQUEST_TIMEOUT_MS=10000
PROVIDER_MAX_RETRIES=2

# Etherscan V2 (ETH)
ETHERSCAN_API_URL=https://api.etherscan.io/v2/api
ETHERSCAN_API_KEY=
ETHERSCAN_CHAIN_ID=1
ETH_CONFIRMATIONS_MIN=3
ETH_TX_SCAN_LIMIT=100

# TronGrid (USDT TRC20)
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_CONFIRMATIONS_MIN=20
TRON_TX_SCAN_LIMIT=100

# Wallet addresses
USDT_WALLET_ADDRESS=TXLAQ63Xg1NAzckPwKHvzw7CSEmLMEqcdj
BTC_WALLET_ADDRESS=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
ETH_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc454e4438f44e

# Networks labels
USDT_NETWORK=TRC20
BTC_NETWORK=BTC
ETH_NETWORK=ERC20

# Optional local HTTPS
SSL_CERT_PATH=
SSL_KEY_PATH=
